{
  "name": "sidecar-cli",
  "version": "0.1.3-beta.1",
  "description": "Local-first project memory and recording tool",
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "node -e \"console.log('No tests configured')\"",
    "pack_release": "node scripts/create-release-tarball.mjs",
    "clean": "node scripts/clean-dist.mjs",
    "release_check": "node scripts/release-check.mjs",
    "release:cut": "node scripts/cut-release.mjs",
    "release:stable": "node scripts/cut-release.mjs --channel stable",
    "release:beta": "node scripts/cut-release.mjs --channel beta",
    "release:rc": "node scripts/cut-release.mjs --channel rc",
    "sidecar:reminder": "node scripts/sidecar-reminder.mjs",
    "install:hooks": "node scripts/install-git-hooks.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "private": false,
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "semver": "^7.7.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/semver": "^7.7.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "bin": {
    "sidecar": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
